# ES/KBN DOCKERFILE options:
#   Dockerfile-use-ror-binaries-from-api  - download ROR plugin from API (requires ROR_ES_VERSION / ROR_KBN_VERSION)
#   Dockerfile-use-ror-binaries-from-file - use a local plugin file (requires ES_ROR_FILE / KBN_ROR_FILE)

ES_VERSION=9.3.3
ES_DOCKERFILE=Dockerfile-use-ror-binaries-from-api
ROR_ES_VERSION=1.69.1

KBN_VERSION=9.3.3
KBN_DOCKERFILE=Dockerfile-use-ror-binaries-from-api
ROR_KBN_VERSION=1.69.1

# Number of Kibana instances to start (each gets its own confs/kibana-N.yml)
KBN_INSTANCES=2

# Controls whether Kibana rewrites the base path (true) or the reverse proxy does (false).
# true  - Kibana strips /ror-demo before processing requests (server.rewriteBasePath: true)
# false - Apache strips /ror-demo before forwarding to Kibana (server.rewriteBasePath: false)
REWRITE_BASE_PATH_BY_KIBANA=false